{
  "meta": {
    "siteName": "mongolian-secret-history",
    "visualDirection": "organic-luxury",
    "motionLevel": 2,
    "defaultLocale": "mn",
    "locales": ["mn", "en"]
  },
  "colors": {
    "brand": {
      "primary": "#2D5A4A",
      "accent": "#C9A227",
      "primaryDark": "#1E3D31",
      "accentDark": "#A8891F"
    },
    "neutral": {
      "50": "#FAF9F6",
      "100": "#F8F6F1",
      "200": "#E5E2DC",
      "300": "#C9C5BC",
      "400": "#8A857A",
      "500": "#5C5C5C",
      "600": "#3D3D3D",
      "700": "#1A1A1A",
      "800": "#0F1412",
      "900": "#0A0E0D"
    },
    "semantic": {
      "background": "#F8F6F1",
      "foreground": "#1A1A1A",
      "card": "#FFFFFF",
      "cardForeground": "#1A1A1A",
      "popover": "#FFFFFF",
      "popoverForeground": "#1A1A1A",
      "primary": "#2D5A4A",
      "primaryForeground": "#FFFFFF",
      "secondary": "#F8F6F1",
      "secondaryForeground": "#1A1A1A",
      "muted": "#E5E2DC",
      "mutedForeground": "#5C5C5C",
      "accent": "#C9A227",
      "accentForeground": "#1A1A1A",
      "border": "#E5E2DC",
      "input": "#E5E2DC",
      "ring": "#2D5A4A",
      "success": "#2D5A4A",
      "warning": "#C9A227",
      "destructive": "#B42318"
    }
  },
  "typography": {
    "families": {
      "display": "Playfair Display",
      "body": "Inter",
      "mono": "JetBrains Mono"
    },
    "scale": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem",
      "4xl": "2.25rem",
      "5xl": "3rem",
      "6xl": "3.75rem",
      "7xl": "4.5rem"
    }
  },
  "spacing": {
    "scale": {
      "0": "0px",
      "1": "4px",
      "2": "8px",
      "3": "12px",
      "4": "16px",
      "5": "20px",
      "6": "24px",
      "8": "32px",
      "10": "40px",
      "12": "48px",
      "16": "64px",
      "20": "80px",
      "24": "96px"
    },
    "layout": {
      "pagePadding": "80px",
      "sectionPaddingY": "120px",
      "maxWidth": "1280px",
      "contentWidth": "1200px"
    }
  },
  "radius": {
    "sm": "8px",
    "md": "12px",
    "lg": "16px",
    "xl": "20px",
    "full": "9999px"
  },
  "shadows": {
    "sm": "0 1px 2px 0 rgba(0,0,0,0.05)",
    "md": "0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -2px rgba(0,0,0,0.1)",
    "lg": "0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -4px rgba(0,0,0,0.1)",
    "xl": "0 20px 25px -5px rgba(0,0,0,0.1), 0 8px 10px -6px rgba(0,0,0,0.1)"
  },
  "motion": {
    "duration": {
      "fast": "150ms",
      "normal": "250ms",
      "slow": "350ms"
    },
    "easing": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "in": "cubic-bezier(0.4, 0, 1, 1)",
      "out": "cubic-bezier(0, 0, 0.2, 1)",
      "bounce": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "spring_configs": {
      "gentle": { "stiffness": 120, "damping": 20 },
      "snappy": { "stiffness": 300, "damping": 25 }
    },
    "variants": {
      "fadeInUp": {
        "initial": { "opacity": 0, "y": 24 },
        "animate": { "opacity": 1, "y": 0 },
        "transition": { "duration": 0.5, "ease": "out" }
      },
      "staggerContainer": {
        "animate": { "transition": { "staggerChildren": 0.1 } }
      },
      "cardHover": {
        "rest": { "y": 0, "boxShadow": "0 1px 2px rgba(0,0,0,0.05)" },
        "hover": { "y": -4, "boxShadow": "0 10px 15px -3px rgba(0,0,0,0.1)" }
      },
      "buttonHover": {
        "rest": { "scale": 1 },
        "hover": { "scale": 1.02 }
      }
    },
    "gsap_configs": {},
    "scroll_behavior": "smooth",
    "prefers_reduced_motion": true
  }
}
